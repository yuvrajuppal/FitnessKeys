model Category {
    id        String   @id @default(cuid())
    name      String   @unique
    imageUrl  String?
    Showindex BigInt
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Workout {
    id         String   @id @default(cuid())
    categoryId String
    name       String
    imageUrl   String?
    videolink  String   @db.Text
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
}
