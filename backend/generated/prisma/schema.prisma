model AdminUser {
  id             String   @id @default(cuid())
  admin_username String   @unique
  password       String
  name           String
  role           String   @default("admin")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  imageUrl  String?
  Showindex BigInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workout {
  id         String   @id @default(cuid())
  categoryId String
  name       String
  imageUrl   String?
  videolink  String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

generator client {
  provider = "prisma-client-js"

  output = "../../generated/prisma"
}

datasource db {
  provider = "mysql"
}
